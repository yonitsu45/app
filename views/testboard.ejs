<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.0.2/dist/css/bootstrap.min.css" rel="stylesheet" integrity="sha384-EVSTQN3/azprG1Anm3QDgpJLIm9Nao0Yz1ztcQTwFspd3yD65VohhpuuCOmLASjC" crossorigin="anonymous">
    <link rel="stylesheet" href="/css/style.css">
    <title>ECP SMART PET FEEDER</title>
</head>

<style>
  .divider-vertical {
    width: 1px;
    height: 150px;
    background-color: #ccc;
    margin: 0 20px;
  }
</style>

<body class="bgcolor">
    <%- include('partials/navbar') %>

    <div class="container mt-4">
        <div class="card">
            <div class="card-body">
                <h2>ข้อความจาก ESP32</h2>
                <div id="message-log" style="border:1px solid #ccc; padding:10px; height:200px; overflow-y:auto;"></div>

                <script>
                    const socket = new WebSocket("ws://" + location.host);

                    socket.onopen = () => {
                        console.log("✅ WebSocket connected to server");
                    };

                    socket.onmessage = (event) => {
                        const msg = event.data;
                        console.log("📩 ได้รับข้อความจาก server:", msg);

                        // เพิ่มข้อความเข้าไปในกล่อง log
                        const log = document.getElementById("message-log");
                        const p = document.createElement("p");
                        p.textContent = msg;
                        log.appendChild(p);

                        // เลื่อนลงล่างสุดอัตโนมัติ
                        log.scrollTop = log.scrollHeight;
                    };
                </script>
            </div>
        </div>
    </div>
    <script src="https://cdn.jsdelivr.net/npm/@popperjs/core@2.9.2/dist/umd/popper.min.js" integrity="sha384-IQsoLXl5PILFhosVNubq5LC7Qb9DXgDA9i+tQ8Zj3iwWAwPtgFTxbJ8NT4GN1R8p" crossorigin="anonymous"></script>
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.0.2/dist/js/bootstrap.min.js" integrity="sha384-cVKIPhGWiC2Al4u+LWgxfKTRIcfu0JTxR+EQDz/bgldoEyl4H0zUF0QKbrJ0EcQF" crossorigin="anonymous"></script>
</body>
</html>