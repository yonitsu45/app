<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Prompt:wght@300;400;500;600;700&display=swap" rel="stylesheet">
    <link rel="icon" href="https://i.ibb.co/5hZBy3pm/mochi-64x64.png">
    <link rel="stylesheet" href="/css/style.css">
    <title>ECP SMARTPET FEEDER | Account Recovery</title>
</head>
<body>
    <div class="container mt-5">
        <span class ="h3 mt-5 mx-4">🔐 Account Recovery</span>
        <hr>
        <% if (typeof message !== 'undefined' && message) { %>
            <% if (error) { %>
                <div class="alert alert-danger" role="alert"><%= message %></div>
            <% } else { %>
                <div class="alert alert-success" role="alert"><%= message %></div>
                <script>
                    setTimeout(() => {
                        window.location.href = '/index';
                    }, 1000);
                </script>
            <% } %>
        <% } %>
        <form action="/forgot-password" method="post">
            <div class="mb-3">
                <label for="email" class="form-label">E-mail</label>
                <input type="email" name="email" class="form-control" placeholder="อีเมลที่ใช้สมัคร" required>
            </div>
            <button type="submit" class="btn register-btn">ส่งลิงก์กู้คืนรหัสผ่าน</button><a type="button" class="btn login-btn ms-3" href="/">ย้อนกลับ</a>
        </form>
        <hr>
    </div>
</body>
</html>