<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="/css/style.css">
    <link rel="icon" href="https://ibb.co/N2RZPqD5">
    <title>Sign In</title>
</head>
<body>
    <div class="container mt-5">
        <span class ="h3 mt-5 mx-4">Resetting Password</span>
        <hr>
        <% if (typeof message !== 'undefined' && message) { %>
            <% if (error) { %>
                <div class="alert alert-danger" role="alert"><%= message %></div>
            <% } else { %>
                <div class="alert alert-success" role="alert"><%= message %></div>
            <% } %>
        <% } %>
        <form action="/reset-password/<%= token %>" method="post">
            <div class="mb-3">
                <label class="form-label">New Password</label>
                <input type="password" name="password" class="form-control" placeholder="กรอกรหัสใหม่" required minlength="6">
            </div>
            <div class="mb-3">
                <label>Confirm new password</label>
                <input type="password" name="passwordCon" class="form-control" placeholder="ยืนยันรหัสผ่าน" minlength="6">
            </div>
            <button type="submit" class="btn register-btn">Save</button><a type="button" class="btn login-btn ms-3" href="/">ย้อนกลับ</a>
        </form>
        <hr>
    </div>
</body>
</html>