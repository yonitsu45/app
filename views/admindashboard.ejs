<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="/css/style.css">
    <link rel="icon" href="https://ibb.co/N2RZPqD5">
    <title>ECP SMART PET FEEDER</title>
</head>
<body class="bgcolor">
    <%- include('partials/navbar') %>
    <div class="container">
        <h1>ADMIN DASHBOARD</h1>
    </div>
    <div class="container mt-4">
        <% if (typeof message !== 'undefined' && message) { %>
            <div class="alert alert-success">
                <p><%= message %></p>
            </div>
        <% } %>
        <ul class="nav nav-tabs" id="adminTab" role="tablist">
            <li class="nav-item" role="presentation">
                <button class="nav-link active" id="users-tab" data-bs-toggle="tab" data-bs-target="#users" type="button" role="tab" aria-controls="users" aria-selected="true">
                    จัดการผู้ใช้งาน (Users)
                </button>
            </li>
            <li class="nav-item" role="presentation">
                <button class="nav-link" id="feeders-tab" data-bs-toggle="tab" data-bs-target="#feeders" type="button" role="tab" aria-controls="feeders" aria-selected="false">
                    จัดการอุปกรณ์ (Feeders)
                </button>
            </li>
            <li>
                <a role="button" class="nav-link" data-bs-toggle="modal" data-bs-target="#addToken">
                    Add Token
                </a>
            </li>
        </ul>
        <div class="card">
           <div class="tab-content bg-white p-3 border border-top-0 rounded-bottom shadow-sm" id="adminTabContent">
            
            <div class="tab-pane fade show active" id="users" role="tabpanel" aria-labelledby="users-tab">
                <h4 class="mt-2">รายชื่อผู้ใช้งานทั้งหมด (<%= allUsers.length %>)</h4>
                <div class="table-responsive">
                    <table class="table table-hover table-bordered mt-3">
                        <thead class="table-dark">
                            <tr>
                                <th>ID</th>
                                <th>Username</th>
                                <th>Email</th>
                                <th>Role</th>
                                <th>Register date</th>
                                <th>Action</th>
                                </tr>
                        </thead>
                        <tbody>
                            <% allUsers.forEach(u => { %>
                                <tr>
                                    <td><%= u.userID %></td>
                                    <td><%= u.username %></td>
                                    <td><%= u.email %></td>
                                    <td>
                                        <% if(u.urole == 'admin') { %>
                                            <span class="badge bg-danger">Admin</span>
                                        <% } else { %>
                                            <span class="badge bg-primary">User</span>
                                        <% } %>
                                    </td>
                                    <td><%= u.created_at %></td>
                                    <td>
                                        <a role="button" class="badge bg-success edit-btn" data-id="<%= u.userID %>" 
                                                                                data-username="<%= u.username %>"
                                                                                data-email="<%= u.email %>"
                                                                                data-bs-toggle="modal" 
                                                                                data-bs-target="#adminEditUserModal">
                                            <img src="https://www.svgrepo.com/show/522527/edit-3.svg" alt="editbutton" height="16px" width="16px" style="filter: invert(1);">
                                        </a>
                                    </td>
                                    </tr>
                            <% }) %>
                        </tbody>
                    </table>
                </div>
            </div>

            <div class="tab-pane fade" id="feeders" role="tabpanel" aria-labelledby="feeders-tab">
    <h4 class="mt-2">อุปกรณ์ทั้งหมดในระบบ (<%= allFeeders.length %>)</h4>
            <div class="table-responsive">
                    <table class="table table-striped table-bordered mt-3">
                        <thead class="table-dark">
                            <tr>
                                <th>ID</th>
                                <th>Feeder's name</th>
                                <th>Token</th>
                                <th>Owner (Email)</th>
                                <th>Status</th>
                                <th>Action</th>
                            </tr>
                        </thead>
                        <tbody>
                            <% allFeeders.forEach(f => { %>
                                <tr>
                                    <td><%= f.feederID %></td>
                                    <td><%= f.feederName || '-' %></td>
                                    <td><code><%= f.feederToken %></code></td>
                                    <td>
                                        <% if(f.ownerEmail) { %>
                                            <span class="text-primary"><%= f.ownerEmail %></span>
                                        <% } else { %>
                                            <span class="text-muted fst-italic">ยังไม่มีเจ้าของ</span>
                                        <% } %>
                                    </td>
                                    <td>
                                        <% if(f.isActive == 1) { %>
                                            <span class="badge bg-success">Online</span>
                                        <% } else { %>
                                            <span class="badge bg-secondary">Offline</span>
                                        <% } %>
                                    </td>
                                    <td>
                                        <a role="button" class="badge bg-success edit-feeder-btn"
                                        data-id="<%= f.feederID %>"
                                        data-name="<%= f.feederName %>"
                                        data-token="<%= f.feederToken %>"
                                        data-owner-id="<%= f.userID %>" 
                                        data-bs-toggle="modal" 
                                        data-bs-target="#feederEditModal">
                                        <img src="https://www.svgrepo.com/show/522527/edit-3.svg" alt="editbutton" height="16px" width="16px" style="filter: invert(1);">
                                        </a>
                                    </td>
                                </tr>
                            <% }) %>
                        </tbody>
                    </table>
                </div>
            </div>
    </div>
    <%- include('partials/addTokenModal') %>
    <%- include('partials/userEditModal') %>
    <%- include('partials/feederEditModal') %>

<script>
    const editBtns = document.querySelectorAll('.edit-btn');
    editBtns.forEach(btn => {
        btn.addEventListener('click', () => {
            const id = btn.getAttribute('data-id');
            const username = btn.getAttribute('data-username');
            const email = btn.getAttribute('data-email');
            
            const hiddenInput = document.querySelector('#adminEditUserModal input[name="targetID"]');
            const usernameInput = document.querySelector('#adminEditUserModal input[name="username"]');
            const emailInput = document.querySelector('#adminEditUserModal input[name="email"]'); // 🔥 หาช่อง email

            if (hiddenInput) hiddenInput.value = id;
            if (usernameInput) usernameInput.value = username;
            
            if (emailInput) {
                emailInput.value = email;
            }
        });
    });

    const feederBtns = document.querySelectorAll('.edit-feeder-btn');
    
    feederBtns.forEach(btn => {
        btn.addEventListener('click', () => {
            const id = btn.getAttribute('data-id');
            const name = btn.getAttribute('data-name');
            const token = btn.getAttribute('data-token');
            const ownerId = btn.getAttribute('data-owner-id');

            document.getElementById('editFeederID').value = id;
            document.getElementById('editToken').value = token;
            document.getElementById('editFeederName').value = name;
            
            const selectBox = document.getElementById('editFeederOwner');
            if (ownerId) {
                selectBox.value = ownerId; 
            } else {
                selectBox.value = ""; // ถ้าไม่มีเจ้าของ ให้เลือกช่องว่าง
            }
        });
    });
</script>
</body>
</html>