<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="/css/style.css">
    <link rel="icon" href="https://ibb.co/N2RZPqD5">
    <title>ECP SMART PET FEEDER | Dashboard</title>
</head>
<body class="bgcolor">
    <%- include('partials/navbar') %>

    <div class="container mt-4">
        <div class="card">
            <div class="card-body" style="border: 2px; border-color: black;">
                <h1><%= dashboard.dashboardName %></h1>
                <p>หน้านี้เป็น Dashboard ของคุณ (<%= user.username %>)</p>
                <hr>
                <div class="mb-3">
                    <div class="row g-3 mb-4">
                        <div class="col-md-4">
                            <div class="card h-100 shadow-sm"> <div class="card-body d-flex align-items-center justify-content-between">
                                <div>
                                    <h5 class="card-title mb-0">สถานะเครื่อง</h5>
                                    <small class="text-muted" id="masterStatusLabel">
                                        <%= feederStatus == 1 ? 'กำลังทำงาน' : 'หยุดทำงาน' %>
                                    </small>
                                </div>
                                
                                <div class="form-check form-switch mb-0">
                                    <input class="form-check-input" type="checkbox" role="switch" id="masterSwitch"
                                        style="width: 3em; height: 1.5em; cursor: pointer;"
                                        <%= feederStatus == 1 ? 'checked' : '' %> 
                                        onchange="toggleFeederStatus('<%= dashboard.feederID %>')">
                                </div>
                            </div>
                        </div>
                    </div>
                    <div class="col-md-4">
                        <div class="card h-100 shadow-sm border-warning">
                            <div class="card-body text-center">
                                <h5 class="card-title text-warning">FOOD LEVEL</h5>
                                <span class="fw-bold fs-5" id="foodText">0 %</span>
                            </div>
                        </div>
                    </div>
                    <div class="col-md-4">
                        <div class="card h-100 shadow-sm border-primary">
                            <div class="card-body text-center">
                                <h5 class="card-title text-primary">WATER LEVEL</h5>
                                <span class="fw-bold fs-5" id="waterText">0 %</span>
                            </div>
                        </div>
                    </div>

                </div>
                <% if (configs.length > 0) { %>
                    <table class="table">
                        <thead>
                            <tr>
                                <th>เวลา</th>
                                <th>ปริมาณอาหาร (กรัม)</th>
                                <th>ลบ</th>
                            </tr>
                        </thead>
                        <tbody>
                            <% configs.forEach(cfg => { %>
                                <tr>
                                    <td><%= cfg.feedTime %></td>    
                                    <td><%= cfg.feedDura %></td>
                                    <td>
                                        <form action="/config/delete/<%= cfg.conID %>" method="POST" onsubmit="if(confirm('ยืนยันที่จะลบการตั้งค่านี้?')) { notifyServerUpdate(); return true; } else { return false; }">
                                            <input type="hidden" name="dashboardID" value="<%= dashboard.dashboardID %>">
                                            <input type="hidden" name="feederID" value="<%= dashboard.feederID %>">
                                            <button type="submit" class="btn btn-danger btn-sm">
                                                <img src="https://www.svgrepo.com/show/533010/trash-alt.svg" alt="conDelete" width="16" height="16" style="filter: invert(1);">
                                            </button>
                                        </form>
                                    </td>
                                </tr>
                            <% }) %>
                        </tbody>
                    </table>
                <% } else { %>
                    <div class="alert alert-secondary text-center mt-3">
                        ยังไม่มีการตั้งค่าการให้อาหาร
                    </div>
                <% } %>
                <% if (configs.length < 3) { %>
                    <a class="btn btn-primary mt-3 d-block" data-bs-toggle="modal" data-bs-target="#addConfig">+ เพิ่มเวลาให้อาหาร</a>
                <% } else { %>
                    <p class="text-muted">เวลาในการตั้งอาหารเต็มแล้ว (3 ครั้ง)</p>
                <% } %>

                <hr>

                <div class="card mt-3">
                    <div class="card-header bg-dark text-white">Live Camera</div>
                    <div class="card-body text-center">
                        <img id="liveStream" src="" alt="Waiting for stream..." style="max-width: 100%; border-radius: 8px; border: 2px solid #ddd;">
                        <p class="text-muted mt-2" id="camStatus">Connecting...</p>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <script>
        function toggleFeederStatus(feederID) {
            const switchElem = document.getElementById('masterSwitch');
            const labelElem = document.getElementById('masterStatusLabel');
            const isActive = switchElem.checked ? 1 : 0; // 1 = On, 0 = Off

            // อัปเดตข้อความทันทีเพื่อความลื่นไหล
            labelElem.innerText = isActive ? 'ทำงาน' : 'หยุดทำงาน';
            labelElem.style.color = isActive ? 'green' : 'gray';

            // ส่งข้อมูลไปบันทึกที่ Server โดยไม่ต้องรีเฟรชหน้า (ใช้ fetch)
            fetch('/feeder/status', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({ feederID: feederID, isActive: isActive })
            })
            .then(response => response.json())
            .then(data => {
                if (data.success) {
                    console.log('Update success');
                } else {
                    alert('เกิดข้อผิดพลาด: ' + data.message);
                    // ถ้าพัง ให้ดีดสวิตช์กลับ
                    switchElem.checked = !switchElem.checked;
                }
            })
            .catch(err => {
                console.error(err);
                alert('เชื่อมต่อ Server ไม่ได้');
            });
        }
    </script>
    <script>
        // URL ของ WebSocket
        const protocol = window.location.protocol === 'https:' ? 'wss:' : 'ws:';
        const wsUrl = protocol + '//' + window.location.hostname + (window.location.port ? ':' + window.location.port : '');
        const ws = new WebSocket(wsUrl);
        
        const imgElement = document.getElementById('liveStream');
        const statusElement = document.getElementById('camStatus');
        
        const currentFeederID = '<%= dashboard.feederID %>'; 

        ws.onopen = () => {
            console.log('Connected to WS for Feeder ID:', currentFeederID); // log ดูหน่อยว่าได้เลขอะไร
            statusElement.innerText = "Waiting for video...";
            
            ws.send(JSON.stringify({
                type: 'watch',
                feederID: currentFeederID
            }));
        };

        ws.onmessage = (event) => {
            // ถ้าข้อมูลที่ส่งมาเป็น Blob (Binary Image)
            if (event.data instanceof Blob) {
                // แปลง Blob เป็น URL เพื่อแสดงใน <img src>
                const url = URL.createObjectURL(event.data);
                
                // เคลียร์ URL เก่าเพื่อคืน Memory
                imgElement.onload = () => {
                    URL.revokeObjectURL(imgElement.src);
                };
                
                imgElement.src = url;
                statusElement.innerText = "Live";
                statusElement.style.color = "green";
            }
        };

        ws.onclose = () => {
            statusElement.innerText = "Disconnected";
            statusElement.style.color = "red";
        };
    </script>
    <script>

        async function fetchRealtimeData() {
            try {
                const response = await fetch(`/api/feeder/status/${currentFeederID}`);
                const data = await response.json();
                updateUI(data);
            } catch (error) {
                console.error("Error fetching data:", error);
            }
        }

        function updateUI(data) {
            // 1. อัปเดตสถานะเครื่อง
            const switchBtn = document.getElementById('masterSwitch');
            // 🔥 แก้ตรงนี้: เปลี่ยนจาก 'statusText' เป็น 'masterStatusLabel' ให้ตรงกับ HTML
            const statusText = document.getElementById('masterStatusLabel'); 
            
            // เช็คว่า switchBtn มีอยู่จริงไหมก่อนใช้งาน (กัน Error)
            if (switchBtn) {
                if (switchBtn.checked !== (data.isActive == 1)) {
                    switchBtn.checked = (data.isActive == 1);
                }
            }
            
            // เช็คว่า statusText มีอยู่จริงไหมก่อนใช้งาน
            if (statusText) {
                if (data.isActive == 1) {
                    statusText.innerText = "กำลังทำงาน"; // หรือ "Online"
                    statusText.style.color = "green";     // ปรับสีแบบง่ายๆ
                    statusText.className = "text-success fw-bold"; // หรือใช้ Class
                } else {
                    statusText.innerText = "หยุดทำงาน";   // หรือ "Offline"
                    statusText.style.color = "gray";
                    statusText.className = "text-muted fw-bold";
                }
            }

            const foodText = document.getElementById('foodText');
            if (foodText) {
                foodText.innerText = data.foodLevel + " %";
            }
            
            const waterText = document.getElementById('waterText');
            if (waterText) {
                waterText.innerText = data.waterLevel + " %";
            }
        }

        setInterval(fetchRealtimeData, 3000);
        fetchRealtimeData();
    </script>
    <%- include('partials/configModal') %>
</body>
</html>