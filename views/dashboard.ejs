<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
    <script src="https://kit.fontawesome.com/fcb441cbed.js" crossorigin="anonymous"></script>
    <!-- <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css"> -->
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Prompt:wght@300;400;500;600;700&display=swap" rel="stylesheet">
    <link rel="icon" href="https://i.ibb.co/5hZBy3pm/mochi-64x64.png">
    <link rel="stylesheet" href="/css/style.css">
    <title>ECP SMART PET | Dashboard</title>
</head>
<body>
    <%- include('partials/navbar') %>
    <%- include('partials/feederNameEdit') %> 

    <div class="container py-4">
        
        <div class="row align-items-center mb-4">
            <div class="col-md-8">
                <h2 class="fw-bold text-dark mb-0">
                    <i class="fa-solid fa-paw text-primary me-2 overflow-hidden"></i><%= dashboard.dashboardName %>
                    <button class="btn btn-sm btn-outline-secondary ms-2 rounded-circle" data-bs-toggle="modal" data-bs-target="#settingsModal">
                        <i class="fa-solid fa-pen"></i>
                    </button>
                </h2>
                <p class="text-muted mt-1 mb-0">ยินดีต้อนรับ, <%= user.username %> | จัดการเครื่องให้อาหารของคุณ</p>
            </div>
            <div class="col-md-4 text-md-end mt-3 mt-md-0">
                <div class="card card-modern bg-white d-inline-flex flex-column align-items-start px-4 py-3" style="min-width: 250px;">
                    
                    <!-- 🔥 1. แสดงสถานะ WebSocket Connection -->
                    <div class="mb-3 w-100">
                        <small class="text-muted d-block lh-1">📡 สถานะการเชื่อมต่อ</small>
                        <strong id="masterStatusLabel" class="text-danger">
                            🔴 ตัดการเชื่อมต่อ
                        </strong>
                    </div>

                    <!-- 🔥 2. Divider -->
                    <hr class="w-100 my-2">

                    <!-- 🔥 3. ควบคุมการแจ้งเตือน -->
                    <div class="w-100">
                        <small class="text-muted d-block lh-1">🔔 การแจ้งเตือน</small>
                        <div class="form-check form-switch mb-0">
                            <input class="form-check-input" type="checkbox" role="switch" id="notificationSwitch"
                                style="width: 3em; height: 1.5em; cursor: pointer;"
                                <%= feederStatus.isActive == 1 ? 'checked' : '' %> 
                                onchange="toggleNotification('<%= dashboard.feederID %>')">
                            <label class="form-check-label ms-2" for="notificationSwitch">
                                <span id="notificationLabel"><%= feederStatus.isActive == 1 ? '✅ เปิด' : '❌ ปิด' %></span>
                            </label>
                        </div>
                    </div>

                </div>
            </div>
        </div>

        <div class="row g-4">
            <div class="col-lg-7">
                
                <div class="row g-3 mb-4">
                    <div class="col-sm-6">
                        <div class="card card-modern h-100">
                            <div class="card-body">
                                <div class="d-flex justify-content-between align-items-start mb-3">
                                    <div>
                                        <p class="text-muted fw-bold mb-1">ปริมาณอาหารในถัง</p>
                                        <h3 class="fw-bold mb-0 text-dark"><span id="foodText">0</span> %</h3>
                                    </div>
                                    <div class="icon-box bg-food"><i class="fa-solid fa-bone"></i></div>
                                </div>
                                <div class="bg-light rounded p-2 text-center border">
                                    <small class="text-muted">ในถาดพร้อมทาน: <strong id="bowlFoodText" class="text-dark fs-5">0</strong> กรัม</small>
                                </div>
                            </div>
                        </div>
                    </div>
                    <div class="col-sm-6">
                        <div class="card card-modern h-100">
                            <div class="card-body">
                                <div class="d-flex justify-content-between align-items-start mb-3">
                                    <div>
                                        <p class="text-muted fw-bold mb-1">ปริมาณน้ำสำรอง</p>
                                        <h3 class="fw-bold mb-0 text-dark"><span id="waterText">0</span> %</h3>
                                    </div>
                                    <div class="icon-box bg-water"><i class="fa-solid fa-droplet"></i></div>
                                </div>
                                <div class="bg-light rounded p-2 text-center border">
                                    <small class="text-muted">ในถาดพร้อมดื่ม: <strong id="bowlWaterText" class="text-dark fs-5">0</strong> มล.</small>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>

                <div class="card card-modern mb-4">
                    <div class="card-header bg-white border-bottom py-3 d-flex justify-content-between align-items-center">
                        <h5 class="mb-0 fw-bold text-dark"><i class="fa-regular fa-clock me-2"></i>ตารางเวลาให้อาหาร</h5>
                        <span class="badge bg-primary rounded-pill"><%= configs.length %>/3 Slots</span>
                    </div>
                    <div class="card-body p-0">
                        <% if (configs.length > 0) { %>
                            <div class="table-responsive">
                                <table class="table table-hover align-middle mb-0 text-center">
                                    <thead class="table-light text-muted">
                                        <tr>
                                            <th><small>เวลา</small></th>
                                            <th><small>ปริมาณ</small></th>
                                            <th><small>จัดการ</small></th>
                                        </tr>
                                    </thead>
                                    <tbody>
                                        <% configs.forEach(cfg => { %>
                                            <tr>
                                                <td class="fw-bold fs-5 text-dark"><%= cfg.feedTime %></td>    
                                                <td><span class="badge bg-success bg-opacity-10 text-success border border-success px-3 py-2"><%= cfg.feedAmount %> กรัม</span></td>
                                                <td>
                                                    <form action="/config/delete/<%= cfg.conID %>" method="POST" class="d-inline" onsubmit="confirmDeleteSchedule(event, this)">
                                                        <input type="hidden" name="dashboardID" value="<%= dashboard.dashboardID %>">
                                                        <button type="submit" class="btn btn-outline-danger btn-sm rounded-circle" title="ลบเวลา"><i class="fa-solid fa-trash"></i></button>
                                                    </form>
                                                </td>
                                            </tr>
                                        <% }) %>
                                    </tbody>
                                </table>
                            </div>
                        <% } else { %>
                            <div class="text-center text-muted py-5">
                                <i class="fa-regular fa-calendar-xmark fs-1 mb-2 opacity-50"></i>
                                <p class="mb-0">ยังไม่มีการตั้งเวลาให้อาหาร</p>
                            </div>
                        <% } %>
                    </div>
                    <div class="card-footer bg-white border-top-0 p-3 text-center">
                        <% if (configs.length < 3) { %>
                            <button class="btn btn-primary w-100 fw-bold rounded-pill shadow-sm" data-bs-toggle="modal" data-bs-target="#addConfig">
                                <i class="fa-solid fa-plus me-1"></i> เพิ่มเวลาให้อาหาร
                            </button>
                        <% } else { %>
                            <div class="alert alert-warning mb-0 py-2"><i class="fa-solid fa-circle-exclamation me-2"></i>ตั้งเวลาเต็มจำนวน 3 ครั้งแล้ว</div>
                        <% } %>
                    </div>
                </div>

                <div class="card card-modern mb-4">
                    <div class="card-header bg-dark text-white py-2 d-flex justify-content-between align-items-center border-0" style="border-radius: 15px 15px 0 0;">
                        <span class="fw-bold"><i class="fa-solid fa-video me-2"></i>Live Camera</span>
                        <span id="camStatus" class="badge bg-secondary">Connecting...</span>
                    </div>
                    <div class="card-body p-0 bg-black text-center" style="border-radius: 0 0 15px 15px; min-height: 200px; display: flex; align-items: center; justify-content: center;">
                        <img id="liveStream" src="" alt="Waiting for stream..." class="img-fluid w-100" style="border-radius: 0 0 15px 15px; object-fit: cover;">
                    </div>
                </div>
            </div>

            <div class="col-lg-5">
                
                <div class="card card-modern bg-primary text-white mb-4 overflow-hidden position-relative">
                    <i class="fa-solid fa-bowl-food position-absolute opacity-10" style="font-size: 8rem; right: -20px; top: -10px;"></i>
                    <div class="card-body position-relative z-1 p-4">
                        <h5 class="fw-bold mb-3"><i class="fa-solid fa-bolt me-2"></i>สั่งให้อาหารทันที</h5>
                        <div class="input-group input-group-lg shadow-sm">
                            <input type="number" id="manualFeedAmount" class="form-control text-center fw-bold" value="10" min="10" max="1000" step="10" placeholder="กรัม">
                            <span class="input-group-text bg-white text-dark">g.</span>
                            <button class="btn btn-warning fw-bold px-4" type="button" onclick="sendManualFeed()">จ่ายอาหาร</button>
                        </div>
                    </div>
                </div>

                <div class="card card-modern mb-4">
                    <div class="card-header bg-white border-bottom py-3 d-flex justify-content-between align-items-center">
                        <h6 class="mb-0 fw-bold text-dark"><i class="fa-solid fa-clock-rotate-left me-2"></i>ประวัติล่าสุด</h6>
                        <div>
                            <button class="btn btn-sm btn-outline-danger border me-1" onclick="clearLogs()" title="ล้างประวัติทั้งหมด">
                                <i class="fa-solid fa-trash"></i>
                            </button>
                            <button class="btn btn-sm btn-light border" onclick="refreshLogs()" title="โหลดประวัติใหม่">
                                <i class="fa-solid fa-rotate-right"></i>
                            </button>
                        </div>
                    </div>
                    <ul class="list-group list-group-flush log-scroll" id="feedLogList">
                        <% if (logs.length > 0) { %>
                            <% logs.forEach(log => { %>
                                <li class="list-group-item d-flex justify-content-between align-items-center py-3 border-bottom-0">
                                    <div class="d-flex align-items-center">
                                        <div class="icon-box bg-light me-3" style="width: 36px; height: 36px; font-size: 14px;">
                                            <i class="<%= log.type === 'manual' ? 'fa-solid fa-hand text-warning' : 'fa-solid fa-alarm-clock text-primary' %>"></i>
                                        </div>
                                        <div>
                                            <span class="d-block fw-bold text-dark"><%= log.amount %> กรัม</span>
                                            <small class="text-muted">
                                                <%= new Date(log.feedAt).toLocaleString('th-TH-u-ca-gregory', { day: 'numeric', month: 'short', year: 'numeric', hour: '2-digit', minute: '2-digit' , second: '2-digit'}) %> น.
                                            </small>
                                        </div>
                                    </div>
                                    <span class="badge bg-light text-dark border"><%= log.type === 'manual' ? 'สั่งมือ' : 'อัตโนมัติ' %></span>
                                </li>
                            <% }) %>
                        <% } else { %>
                            <li class="list-group-item text-center text-muted py-5 border-bottom-0">ไม่มีประวัติการให้อาหาร</li>
                        <% } %>
                    </ul>
                </div>

            </div>
        </div>
    </div>

<script>
    // ========================================
    // Initialize - Sync with Local Storage
    // ========================================
    document.addEventListener('DOMContentLoaded', function() {
        const currentFeederID = '<%= dashboard.feederID %>';
        const notificationSwitch = document.getElementById('notificationSwitch');
        const notificationLabel = document.getElementById('notificationLabel');
        
        // 🔥 เช็ค Local Storage ถ้ามีการตั้งค่าที่ยังไม่ได้ Sync
        const localNotificationState = localStorage.getItem(`feeder_${currentFeederID}_notification`);
        
        if (localNotificationState !== null) {
            console.log(`📱 Found Local Storage: ${localNotificationState}`);
            const isActive = parseInt(localNotificationState);
            
            if (isActive !== (notificationSwitch.checked ? 1 : 0)) {
                console.log(`🔄 Syncing from Local Storage...`);
                notificationSwitch.checked = isActive === 1;
                notificationLabel.innerText = isActive === 1 ? '✅ เปิด' : '❌ ปิด';
                
                // 🔥 พยายาม Sync ไปหา Server อีกครั้ง
                syncNotificationToServer(currentFeederID, isActive);
            }
        }
    });

    // ========================================
    // Helper Function - Retry Sync to Server
    // ========================================
    function syncNotificationToServer(feederID, isActive) {
        console.log(`🔄 Retrying to sync: feeder_${feederID} = ${isActive}`);
        
        fetch('/feeder/notification', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ feederID: feederID, isActive: isActive })
        })
        .then(response => response.json())
        .then(data => {
            if (data.success) {
                console.log(`✅ Successfully synced to Server`);
                localStorage.removeItem(`feeder_${feederID}_notification`);
            }
        })
        .catch(err => {
            console.error('❌ Sync failed, will retry next time');
        });
    }


    function toggleNotification(feederID) {
        const switchElem = document.getElementById('notificationSwitch');
        const labelElem = document.getElementById('notificationLabel');
        const isActive = switchElem.checked ? 1 : 0;

        // อัปเดตข้อความทันที
        labelElem.innerText = isActive ? '✅ เปิด' : '❌ ปิด';

        localStorage.setItem(`feeder_${feederID}_notification`, isActive);
        console.log(`💾 บันทึกสถานะไว้ใน Browser: ${isActive}`);

        // ส่งไปหา Server
        fetch('/feeder/notification', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ feederID: feederID, isActive: isActive })
        })
        .then(response => {
            if (!response.ok) throw new Error(`HTTP ${response.status}`);
            return response.json();
        })
        .then(data => {
            if (data.success) {
                console.log(`✅ Server บันทึก: ${data.message}`);
            } else {
                themeSwal.fire({
                icon: 'error',
                title: 'เกิดข้อผิดพลาด',
                text: data.message
            });
                switchElem.checked = !switchElem.checked;
                labelElem.innerText = isActive ? '❌ ปิด' : '✅ เปิด';
            }
        })
        .catch(err => {
            console.error(err);
            themeSwal.fire({
                icon: 'warning',
                title: 'เตือน',
                text: 'ไม่สามารถเชื่อมต่อ Server ได้ แต่ตั้งค่าอาจบันทึกไว้ท้องถิ่น',
                confirmButtonText: 'ตกลง'
            });
            switchElem.checked = !switchElem.checked;
        });
    }
    // ========================================
    // WebSocket Setup
    // ========================================
    const protocol = window.location.protocol === 'https:' ? 'wss:' : 'ws:';
    const wsUrl = protocol + '//' + window.location.hostname + (window.location.port ? ':' + window.location.port : '');
    const ws = new WebSocket(wsUrl);
    
    const currentFeederID = '<%= dashboard.feederID %>';
    const imgElement = document.getElementById('liveStream');
    const statusElement = document.getElementById('camStatus');
    const statusLabel = document.getElementById('masterStatusLabel');

    // ========================================
    // WebSocket Connection Event
    // ========================================
    ws.onopen = () => {
        console.log('✅ WebSocket connected to Server');
        
        // ส่ง watch command
        ws.send(JSON.stringify({
            type: 'watch',
            feederID: currentFeederID
        }));

        // ลบส่วนนี้ออก (ไม่ต้อง toggle status แล้ว)
        // ws.send(JSON.stringify({
        //     type: 'force_update_client',
        //     targetID: currentFeederID
        // }));
    };

    // ========================================
    // WebSocket Message Handler (Real-time)
    // ========================================
    ws.onmessage = (event) => {
        // ===== Handle Binary (Camera Stream) =====
        if (event.data instanceof Blob) {
            const url = URL.createObjectURL(event.data);
            imgElement.onload = () => URL.revokeObjectURL(imgElement.src);
            imgElement.src = url;
            statusElement.innerText = "🟢 Live";
            statusElement.style.color = "green";
            return;
        }

        // ===== Handle JSON Messages =====
        try {
            const data = JSON.parse(event.data);

            // 🔥 1️⃣ Device Status (MAIN - Check ESP32 Connection)
            if (data.type === 'device_status') {
                console.log(`📡 Device Status: ${data.status}`);
                
                if (data.status === 'online') {
                    // ✅ ESP32 เชื่อมต่อมาแล้ว
                    statusLabel.innerText = '🟢 เชื่อมต่อแล้ว (Online)';
                    statusLabel.className = 'text-success fw-bold';
                } else if (data.status === 'offline') {
                    // ❌ ESP32 ตัดการเชื่อมต่อ
                    statusLabel.innerText = '🔴 ตัดการเชื่อมต่อ (Offline)';
                    statusLabel.className = 'text-danger fw-bold';
                }
            }

            // 🔥 2️⃣ Sensor Update (Real-time from ESP32)
            if (data.type === 'update_sensor') {
                const foodText = document.getElementById('foodText');
                if (foodText) foodText.innerText = data.food;
                
                const waterText = document.getElementById('waterText');
                if (waterText) waterText.innerText = data.water;
                
                const bowlFoodText = document.getElementById('bowlFoodText');
                if (bowlFoodText) bowlFoodText.innerText = data.bowlFood;
                
                const bowlWaterText = document.getElementById('bowlWaterText');
                if (bowlWaterText) bowlWaterText.innerText = data.bowlWater;
            }

            // 3️⃣ Schedule Update
            if (data.type === 'schedule_update') {
                console.log('📅 Schedule updated');
            }

        } catch (err) {
            console.log('Non-JSON message received');
        }
    };

    // ========================================
    // WebSocket Closed Event
    // ========================================
    ws.onclose = () => {
        console.log('❌ WebSocket disconnected from Server');
        statusElement.innerText = "🔴 Disconnected";
        statusElement.style.color = "red";
        statusLabel.innerText = '🔴 ตัดการเชื่อมต่อ (No WS)';
        statusLabel.className = 'text-danger fw-bold';
    };

    ws.onerror = (error) => {
        console.error('❌ WebSocket Error:', error);
    };

    // ========================================
    // Manual Feed Function
    // ========================================
    function sendManualFeed() {
        const amountInput = document.getElementById('manualFeedAmount').value;
        const amount = parseInt(amountInput);

        if (isNaN(amount) || amount <= 0) {
            themeSwal.fire({
                icon: 'error',
                title: 'ข้อมูลไม่ถูกต้อง',
                text: 'กรุณาใส่ปริมาณอาหารให้ถูกต้อง',
                confirmButtonText: 'ตกลง'
            });
            return;
        }

        if (ws && ws.readyState === WebSocket.OPEN) {
            ws.send(JSON.stringify({ 
                type: 'manual_feed', 
                feederID: currentFeederID, 
                amount: amount 
            }));
            
            themeSwal.fire({
                icon: 'success',
                title: 'สั่งการสำเร็จ',
                text: `กำลังสั่งเครื่องจ่ายอาหาร ${amount} กรัม...`,
                showConfirmButton: false,
                timer: 1500
            });
        } else {
            themeSwal.fire({ 
                icon: 'warning', 
                title: 'เครื่องออฟไลน์', 
                text: 'ไม่สามารถส่งคำสั่งได้ เครื่องยังไม่เชื่อมต่อ' 
            });
        }
    }

    // ========================================
    // Refresh Logs Function
    // ========================================
    async function refreshLogs() {
        try {
            const response = await fetch(`/api/feeder/${currentFeederID}/logs`);
            const logs = await response.json();
            
            const logList = document.getElementById('feedLogList');
            logList.innerHTML = '';

            if (logs.length > 0) {
                logs.forEach(log => {
                    const dateObj = new Date(log.feedAt);
                    const timeStr = dateObj.toLocaleString('th-TH-u-ca-gregory', { 
                        day: 'numeric', 
                        month: 'short', 
                        year: 'numeric', 
                        hour: '2-digit', 
                        minute: '2-digit' 
                    }) + ' น.';
                    
                    const isManual = log.type === 'manual';
                    const iconClass = isManual ? 'fa-solid fa-hand text-warning' : 'fa-solid fa-clock text-primary';
                    const badgeText = isManual ? 'สั่งมือ' : 'อัตโนมัติ';
                    
                    const li = document.createElement('li');
                    li.className = 'list-group-item d-flex justify-content-between align-items-center py-3 border-bottom-0';
                    li.innerHTML = `
                        <div class="d-flex align-items-center">
                            <div class="icon-box bg-light me-3" style="width: 36px; height: 36px; font-size: 14px;">
                                <i class="${iconClass}"></i>
                            </div>
                            <div>
                                <span class="d-block fw-bold text-dark">${log.amount} กรัม</span>
                                <small class="text-muted">${timeStr}</small>
                            </div>
                        </div>
                        <span class="badge bg-light text-dark border">${badgeText}</span>
                    `;
                    logList.appendChild(li);
                });
            } else {
                logList.innerHTML = '<li class="list-group-item text-center text-muted py-5 border-bottom-0">ไม่มีประวัติการให้อาหาร</li>';
            }
        } catch (error) {
            console.error("Error refreshing logs:", error);
        }
    }

    // ========================================
    // Clear Logs Function
    // ========================================
    async function clearLogs() {
        const result = await themeSwal.fire({
            icon: 'warning',
            title: 'ยืนยันการล้างประวัติ?',
            text: 'ประวัติทั้งหมดจะถูกลบถาวร ไม่สามารถกู้คืนได้',
            showCancelButton: true,
            confirmButtonText: 'ใช่, ลบทิ้งเลย',
            cancelButtonText: 'ยกเลิก',
            confirmButtonColor: '#dc3545'
        });

        if (result.isConfirmed) {
            try {
                const response = await fetch(`/api/feeder/${currentFeederID}/logs`, { method: 'DELETE' });
                const data = await response.json();
                
                if (data.success) {
                    themeSwal.fire({ icon: 'success', title: 'ล้างประวัติสำเร็จ', timer: 1500, showConfirmButton: false });
                    refreshLogs();
                }
            } catch (error) {
                themeSwal.fire({ icon: 'error', title: 'ล้มเหลว', text: 'ไม่สามารถติดต่อ Server ได้' });
            }
        }
    }

    // ========================================
    // Delete Schedule Function
    // ========================================
    function confirmDeleteSchedule(event, formElement) {
        event.preventDefault(); 

        themeSwal.fire({
            icon: 'warning',
            title: 'ยืนยันการลบตารางเวลา',
            text: '⚠️ คำเตือน: ยืนยันที่จะลบตารางเวลานี้',
            showCancelButton: true,
            confirmButtonColor: '#dc3545',
            cancelButtonColor: '#6c757d',
            confirmButtonText: 'ใช่, ลบทิ้งเลย!',
            cancelButtonText: 'ยกเลิก'
        }).then((result) => {
            if (result.isConfirmed) {
                formElement.submit();
            }
        });
    }

    // 🔥 ลบส่วนนี้ออก (ไม่ต้องใช้ Polling แล้ว)
