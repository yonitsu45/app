<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="/css/style.css">
    <title>ECP SMART PET FEEDER</title>
</head>
<body class="bgcolor">
    <%- include('partials/navbar') %>

    <div class="container mt-4">
        <div class="card">
            <div class="card-body" style="border: 2px; border-color: black;">
                <% if (typeof message !== 'undefined' && message) { %>
                    <div class="alert alert-success">
                        <p><%= message %></p>
                    </div>
                <% } %>

                <% if (typeof user !== 'undefined' && user) { %>
                    <p>สวัสดี <%= user.username %></p>
                    <hr>
                        <% if (dashboards.length > 0) { %>
                            <div class="row">
                                <% dashboards.forEach(d => { %>
                                    <div class="col-md-4 mb-3">
                                        <a href="/dashboard/<%= d.id %>" class="btn btn-secondary mb-2 d-block">
                                            <div>
                                                <div class="card-body overflow-hidden">
                                                    <h5 class="text-light card-title"><%= d.name %></h5>
                                                </div>
                                            </div>
                                        </a>
                                    </div>
                                <% }) %>
                                <a class="btn btn-primary mt-3 d-block" data-bs-toggle="modal" data-bs-target="#addDashboard">+ เพิ่ม Dashboard</a>
                            </div>
                        <% } else { %>
                            <p class="text-muted">ยังไม่มี Dashboard</p>
                        <% } %>
                <% } else { %>
                    <p>คุณยังไม่ได้เข้าสู่ระบบ กรุณาเข้าสู่ระบบ</p>
                <% } %>
            </div>
        </div>
    </div>
    <!-- modal -->
    <%- include('partials/namingModal') %>

</body>
</html>