<!DOCTYPE html>
<html lang="th">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <link rel="stylesheet" href="/css/style.css">
    <link rel="icon" href="/images/logo.png">
    <title>ECP SMART PET | โปรไฟล์ของคุณ</title>
    <style>
        body { background-color: #f4f7f6; font-family: 'Prompt', sans-serif; }
        /* สไตล์พิเศษเฉพาะหน้าโปรไฟล์ */
        .profile-header {
            background: linear-gradient(135deg, #e3f2fd 0%, #bbdefb 100%);
            border-radius: 15px 15px 0 0;
            padding: 2rem;
            text-align: center;
        }
        .profile-avatar {
            width: 100px;
            height: 100px;
            background-color: #fff;
            border-radius: 50%;
            display: inline-flex;
            align-items: center;
            justify-content: center;
            font-size: 3rem;
            color: #0d6efd;
            box-shadow: 0 5px 15px rgba(0,0,0,0.1);
            border: 4px solid #fff;
        }
        .profile-card-modern {
            border: none;
            border-radius: 15px;
            box-shadow: 0 4px 15px rgba(0,0,0,0.05);
            background-color: #fff;
            overflow: hidden;
        }
    </style>
</head>
<body>
    <%- include('partials/navbar') %>

    <div class="container py-5">
        
        <% if (typeof message !== 'undefined' && message) { %>
            <div class="alert alert-success alert-dismissible fade show shadow-sm" role="alert">
                <i class="fa-solid fa-circle-check me-2"></i><%= message %>
                <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
            </div>
        <% } %>

        <div class="row g-4 justify-content-center">
            
            <div class="col-lg-8">
                <div class="profile-card-modern">
                    <div class="profile-header">
                        <div class="profile-avatar mb-2">
                            <%= user.username.charAt(0).toUpperCase() %>
                        </div>
                        <h3 class="fw-bold text-dark mb-0"><%= user.username %></h3>
                        <small class="text-muted"><i class="fa-solid fa-calendar-days me-1"></i>สมาชิกตั้งแต่: มกราคม 2024</small>
                    </div>

                    <div class="card-body p-4">
                        <div class="row g-4">
                            <div class="col-md-7">
                                <h5 class="fw-bold text-dark mb-3"><i class="fa-regular fa-id-card me-2"></i>ข้อมูลบัญชี</h5>
                                
                                <div class="list-group list-group-flush border rounded">
                                    <div class="list-group-item d-flex justify-content-between align-items-center py-3">
                                        <div class="text-muted"><i class="fa-solid fa-user me-2 text-primary"></i>ชื่อผู้ใช้</div>
                                        <div class="fw-bold text-dark"><%= user.username %></div>
                                    </div>
                                    <div class="list-group-item d-flex justify-content-between align-items-center py-3">
                                        <div class="text-muted"><i class="fa-solid fa-envelope me-2 text-primary"></i>อีเมล</div>
                                        <div class="fw-bold text-dark"><%= user.email %></div>
                                    </div>
                                    <div class="list-group-item d-flex justify-content-between align-items-center py-3">
                                        <div class="text-muted"><i class="fa-solid fa-phone me-2 text-primary"></i>เบอร์โทรศัพท์</div>
                                        <div class="fw-bold text-dark"><%= user.phone %></div>
                                    </div>
                                </div>
                                
                                <div class="d-flex gap-2 mt-3">
                                    <button class="btn btn-primary rounded-pill w-100 fw-bold shadow-sm" data-bs-toggle="modal" data-bs-target="#profileEdit">
                                        <i class="fa-solid fa-pen me-1"></i>แก้ไขข้อมูล
                                    </button>
                                    <button class="btn btn-outline-secondary rounded-pill w-100 fw-bold" data-bs-toggle="modal" data-bs-target="#passwordEdit">
                                        <i class="fa-solid fa-key me-1"></i>เปลี่ยนรหัสผ่าน
                                    </button>
                                </div>
                            </div>

                            <div class="col-md-5">
                                <h5 class="fw-bold text-dark mb-3"><i class="fa-solid fa-gear me-2"></i>การตั้งค่าและการใช้งาน</h5>
                                
                                <div class="card bg-light border-0 mb-3">
                                    <div class="card-body py-3">
                                        <p class="fw-bold text-dark mb-3"><i class="fa-solid fa-bell me-1 text-danger"></i>การตั้งค่าแจ้งเตือน</p>
                                        <div class="form-check form-switch mb-2">
                                            <input class="form-check-input" type="checkbox" role="switch" id="feedSuccessNoti" checked>
                                            <label class="form-check-label text-muted" for="feedSuccessNoti"><i class="fa-solid fa-bone me-1"></i>จ่ายอาหารสำเร็จ</label>
                                        </div>
                                        <div class="form-check form-switch mb-2">
                                            <input class="form-check-input" type="checkbox" role="switch" id="lowFoodNoti">
                                            <label class="form-check-label text-muted" for="lowFoodNoti"><i class="fa-solid fa-exclamation-triangle me-1"></i>อาหารใกล้หมด</label>
                                        </div>
                                        <div class="form-check form-switch mb-0">
                                            <input class="form-check-input" type="checkbox" role="switch" id="waterEmptyNoti" checked>
                                            <label class="form-check-label text-muted" for="waterEmptyNoti"><i class="fa-solid fa-droplet me-1"></i>น้ำหมด</label>
                                        </div>
                                    </div>
                                </div>

                                <div class="row g-2 text-center">
                                    <div class="col-6">
                                        <div class="card card-modern h-100 bg-white border p-2">
                                            <small class="text-muted d-block lh-1">เครื่องที่เชื่อมต่อ</small>
                                            <strong class="text-dark fs-3">3</strong>
                                        </div>
                                    </div>
                                    <div class="col-6">
                                        <div class="card card-modern h-100 bg-white border p-2">
                                            <small class="text-muted d-block lh-1">จ่ายอาหารเดือนนี้</small>
                                            <strong class="text-dark fs-3">520<span class="fs-6">g.</span></strong>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>

                    <div class="card-footer bg-white border-top-0 p-3 text-center">
                        <form action="/auth/logout" method="GET" onsubmit="return confirm('ยืนยันที่จะออกจากระบบ?');">
                            <button type="submit" class="btn btn-outline-danger rounded-pill fw-bold w-100">
                                <i class="fa-solid fa-sign-out-alt me-1"></i>ออกจากระบบ
                            </button>
                        </form>
                    </div>
                </div>
            </div>

            <div class="col-12 text-center mt-3">
                <a href="/home" class="btn btn-light rounded-pill border shadow-sm px-4">
                    <i class="fa-solid fa-arrow-left me-2"></i>ย้อนกลับหน้าแรก
                </div>
            </div>

        </div>
    </div>

    <%- include('partials/profileEditModal') %> 

</body>
</html>