<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="/css/style.css">
    <link rel="icon" href="https://ibb.co/N2RZPqD5">
    <title>ECP SMART PET FEEDER</title>
</head>

<style>
  .divider-vertical {
    width: 1px;
    height: 150px;
    background-color: #ccc;
    margin: 0 20px;
  }
</style>

<body class="bgcolor">
    <%- include('partials/navbar') %>

    <div class="container mt-4">
        <div class="card">
            <div class="card-body" style="border: 2px; border-color: black;">
                <div class="container" style="display: flex; align-items: center; justify-content: center;">
                    <div>
                        <img src="https://www.svgrepo.com/show/498301/profile-circle.svg" alt="profilepic" width="128" height="128">
                    </div>
                    
                    <div class="divider-vertical"></div>
                    
                    <div class="container">
                        <h5>Username : </h5></span><p><%= user.username %></p>
                        <h5>Email : </h5></span><p><%= user.email %></p>
                    </div>
                </div>
            </div>
        </div>
    </div>
</body>
</html>