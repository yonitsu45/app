<div class="modal fade" id="adminEditUserModal" tabindex="-1">
    <div class="modal-dialog">
        <div class="modal-content">
            
            <div class="modal-header bg-dark text-white">
                <h5 class="modal-title">แก้ไขข้อมูลผู้ใช้ (Admin Mode)</h5>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
            </div>

            <form action="/user/update" method="POST">
                <div class="modal-body">
                    <input type="hidden" name="targetID" id="adminEditId">

                    <div class="mb-3">
                        <label>Username</label>
                        <input type="text" class="form-control" name="username" id="adminEditUsername" required>
                    </div>
                    
                    <div class="mb-3">
                        <label>E-mail</label>
                        <input type="text" class="form-control" name="email" id="adminEditEmail" required>
                    </div>

                    <div class="mb-3">
                        <label>เปลี่ยนรหัสผ่านใหม่ (ถ้าจะเปลี่ยน)</label>
                        <input type="password" class="form-control" name="newPassword">
                    </div>
                    <div class="mb-3">
                        <label>ยืนยันรหัสผ่าน</label>
                        <input type="password" class="form-control" name="confirmPassword">
                    </div>
                </div>
                <div class="modal-footer">
                    <button type="submit" class="btn btn-success w-100">บันทึกข้อมูล</button>
                </div>
            </form>
            <hr class="m-0 border-danger border-2 opacity-50">

            <div class="modal-body bg-light">
                <form action="/user/delete" method="POST" onsubmit="confirmDeleteUser(event, this)">
                    <input type="hidden" name="targetUserID" id="deleteTargetUserID">
                    
                    <label class="form-label text-danger fw-bold">ลบบัญชีผู้ใช้งาน</label>
                    <div class="input-group input-group-sm">
                        <input type="password" name="password" class="form-control border-danger" placeholder="ใส่รหัส Admin เพื่อยืนยัน" required>
                        <button type="submit" class="btn btn-danger">🗑️ ลบ User</button>
                    </div>
                </form>
            </div>
            </div>
    </div>
</div>

<script>
function confirmDeleteUser(event, formElement) {
    event.preventDefault(); 

    themeSwal.fire({
        icon: 'warning',
        title: 'ยืนยันการลบ User?',
        text: '⚠️ คำเตือน: ยืนยันที่จะลบ User นี้ พร้อมเคลียร์เครื่องที่เชื่อมต่ออยู่ทั้งหมดหรือไม่?',
        showCancelButton: true,
        confirmButtonColor: '#dc3545',
        cancelButtonColor: '#6c757d',
        confirmButtonText: 'ใช่, ลบทิ้งเลย!',
        cancelButtonText: 'ยกเลิก'
    }).then((result) => {
        if (result.isConfirmed) {
            formElement.submit();
        }
    });
}
</script>