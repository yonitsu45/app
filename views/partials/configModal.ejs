<div class="modal fade" id="addConfig" tabindex="-1" aria-labelledby="addConfig" aria-hidden="true">
    <div class="modal-dialog">
        <div class="modal-content">
            <form action="/dashboard/<%= dashboard.feederID %>/config" method="POST" onsubmit="notifyServerUpdate()">
                
                <input type="hidden" name="dashboardID" value="<%= dashboard.dashboardID %>">
                <div class="modal-header">
                    <h5 class="modal-title" id="addDashboardLabel">เพิ่มเวลาให้อาหารใหม่</h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
                </div>

                <div class="modal-body">
                    <div class="mb-3">
                        <label class="form-label">เลือกเวลา (ชั่วโมง : นาที)</label>
                        <input type="time" name="feedTime" class="form-control" required> 
                    </div>

                    <div class="mb-3">
                        <label for="feedDuration" class="form-label">ปริมาณอาหารที่ปล่อย (กรัม)</label>
                        <input type="number" 
                               name="duration" 
                               class="form-control" 
                               id="feedDuration" 
                               placeholder="เช่น 250" 
                               required
                               min="1"
                               max="1000"
                               oninput="this.value = !!this.value && Math.abs(this.value) >= 0 ? Math.abs(this.value) : null">
                    </div>
                </div>

                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">ยกเลิก</button>
                    <button type="submit" class="btn btn-success">บันทึก</button>
                </div>
            </form>
        </div>
    </div>
</div>

<script>
    function notifyServerUpdate() {
        // ดึง ID เครื่องปัจจุบันจาก EJS variable
        const feederID = '<%= dashboard.feederID %>'; 
        
        if (typeof ws !== 'undefined' && ws.readyState === WebSocket.OPEN) {
            
            ws.send(JSON.stringify({
                type: 'force_update_client', // สั่งให้ Server รู้ว่ามีการอัปเดต
                targetID: feederID
            }));
            
            console.log("🔔 แจ้ง Server ให้รีเฟรช ESP32 เรียบร้อยแล้ว");
        } else {
            console.log("⚠️ WebSocket ยังไม่เชื่อมต่อ หรือตัวแปร ws หาไม่เจอ");
        }
    }
</script>
