<div class="modal fade" id="feederEditModal" tabindex="-1">
    <div class="modal-dialog">
        <div class="modal-content">
            
            <div class="modal-header bg-dark text-white">
                <h5 class="modal-title">ตั้งค่าอุปกรณ์</h5>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
            </div>

            <form action="/feeder/update" method="POST">
                <div class="modal-body">
                    <input type="hidden" name="feederID" id="editFeederID">

                    <div class="mb-3">
                        <label>Feeder's name</label>
                        <input type="text" class="form-control" name="feederName" id="editFeederName">
                    </div>

                    <div class="mb-3">
                        <label>Token</label>
                        <input type="text" class="form-control" name="token" id="editToken">
                    </div>

                    <div class="mb-3">
                        <label>Owner</label>
                        <select class="form-select" name="ownerID" id="editFeederOwner">
                            <option value="">-- ไม่ระบุเจ้าของ (ว่าง) --</option>
                            <% allUsers.forEach(u => { %>
                                <option value="<%= u.userID %>"><%= u.email %></option>
                            <% }) %>
                        </select>
                    </div>
                </div>
                <div class="modal-footer">
                    <button type="submit" class="btn btn-success w-100">บันทึก</button>
                </div>
            </form>
            <hr class="m-0 border-danger border-2 opacity-50">

            <div class="modal-body bg-light">
                <form action="/feeder/delete" method="POST" onsubmit="confirmDeleteFeeder(event, this)">
                    <input type="hidden" name="feederID" id="deleteTargetFeederID">
                    
                    <label class="form-label text-danger fw-bold">ลบเครื่องให้อาหารถาวร</label>
                    <div class="input-group input-group-sm">
                        <input type="password" name="password" class="form-control border-danger" placeholder="ใส่รหัส Admin เพื่อยืนยัน" required>
                        <button type="submit" class="btn btn-danger">🗑️ ลบเครื่อง</button>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

<script>
function confirmDeleteFeeder(event, formElement) {
    event.preventDefault(); 

    themeSwal.fire({
        icon: 'warning',
        title: 'ยืนยันการลบเครื่อง?',
        text: '⚠️ ยืนยันที่จะลบเครื่องนี้ออกจากระบบถาวรใช่หรือไม่? (ข้อมูลตั้งเวลาและประวัติจะถูกลบทิ้งทั้งหมด)',
        showCancelButton: true,
        confirmButtonColor: '#dc3545',
        cancelButtonColor: '#6c757d',
        confirmButtonText: 'ใช่, ลบทิ้งเลย!',
        cancelButtonText: 'ยกเลิก'
    }).then((result) => {
        if (result.isConfirmed) {
            formElement.submit();
        }
    });
}
</script>