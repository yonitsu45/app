<div class="modal fade" id="feederEditModal" tabindex="-1">
    <div class="modal-dialog">
        <div class="modal-content">
            <form action="/feeder/update" method="POST">
                <div class="modal-header">
                    <h5 class="modal-title">ตั้งค่าอุปกรณ์</h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                </div>
                <div class="modal-body">
                    <input type="hidden" name="feederID" id="editFeederID">

                    <div class="mb-3">
                        <label>Feeder's name</label>
                        <input type="text" class="form-control" name="feederName" id="editFeederName">
                    </div>

                    <div class="mb-3">
                        <label>Token</label>
                        <input type="text" class="form-control" name="token" id="editToken">
                    </div>

                    <div class="mb-3">
                        <label>Owner</label>
                        <select class="form-select" name="ownerID" id="editFeederOwner">
                            <option value="">-- ไม่ระบุเจ้าของ (ว่าง) --</option>
                            
                            <% allUsers.forEach(u => { %>
                                <option value="<%= u.userID %>"><%= u.email %></option>
                            <% }) %>
                        </select>
                    </div>
                </div>
                <div class="modal-footer">
                    <button type="submit" class="btn btn-primary">บันทึก</button>
                </div>
            </form>
        </div>
    </div>
</div>