<link rel="stylesheet" href="style.css">

<nav class="navbar navbar-expand-md justify-content-center p-4 custombar mb-5">
    <div class="container-fluid position-relative">
        <button class="btn me-3" type="button" data-bs-toggle="offcanvas" data-bs-target="#offcanvas">
            ☰
        </button>

        <a class="navbar-brand position-absolute start-50 translate-middle-x brand-txt" href="/index">ECP SMART PET FEEDER</a>

        <div class="d-none d-md-flex align-items-center">
            <% if (typeof user !== 'undefined' && user) { %>
                <% if (user.urole == 'admin') { %>
                    <a href="/admindashboard" class="admin-btn mx-2">
                        <img src="https://www.svgrepo.com/show/447556/admin-network.svg" alt="admin-btn" width="15" height="15">
                    </a>
                <% } %>

                <!-- alert -->
                <a class="login-btn dropdown mx-2" href="#" role="button" data-bs-toggle="dropdown">
                    <img src="https://www.svgrepo.com/show/532089/bell-alt.svg" width="16px" height="16px">
                    
                    <% if (typeof alerts !== 'undefined' && alerts.length > 0) { %>
                        <span class="position-absolute top-0 start-100 translate-middle badge rounded-pill bg-danger">
                            <%= alerts.length %>
                        </span>
                    <% } %>
                </a>
                <ul class="dropdown-menu dropdown-menu-end shadow" style="width: 300px;">
                    <li><h6 class="dropdown-header">การแจ้งเตือน</h6></li>
                    
                    <% if (alerts.length === 0) { %>
                        <li><a class="dropdown-item text-muted text-center" href="#">ไม่มีการแจ้งเตือน</a></li>
                    <% } else { %>
                        <% alerts.forEach(feeder => { %>
                            <li>
                                <a class="dropdown-item" href="/dashboard/<%= feeder.dashboardID %>">
                                    <small class="fw-bold d-block"><%= feeder.feederName %></small>
                                    <% if (feeder.foodlvl < 20) { %>
                                        <span class="text-danger" style="font-size: 0.85rem;">⚠️ อาหารต่ำ (<%= feeder.foodlvl %>%)</span><br>
                                    <% } %>
                                    <% if (feeder.waterlvl < 20) { %>
                                        <span class="text-danger" style="font-size: 0.85rem;">💧 น้ำต่ำ (<%= feeder.waterlvl %>%)</span>
                                    <% } %>
                                </a>
                            </li>
                            <li><hr class="dropdown-divider"></li>
                        <% }) %>
                    <% } %>
                </ul>

                <a class="mx-2 login-btn" href="/profile">
                    <img src="https://www.svgrepo.com/show/526700/user-circle.svg" alt="profile" width="16" height="16">
                    <span class="ms-1"><%= user.username %></span>
                </a>
                <form action="/logout" method="GET" class="ms-1 mb-0">
                    <button type="submit" class="register-btn">
                        <img src="https://www.svgrepo.com/show/521174/logout.svg" alt="logout" width="16" height="16" style="filter: invert(1);">
                    </button>
                </form>
            <% } else { %>
                <a href="/login" class="login-btn mx-3">Sign In</a>
                <a href="/register" class="register-btn">Sign Up</a>
            <% } %>
        </div>

        <!-- responsive noti -->
        <div class="d-flex d-md-none ms-2">
            <a class="text-decoration-none dropdown mx-2" href="#" role="button" data-bs-toggle="dropdown">
                <img src="https://www.svgrepo.com/show/532089/bell-alt.svg" width="16px" height="16px">
                
                <% if (typeof alerts !== 'undefined' && alerts.length > 0) { %>
                    <span class="position-absolute top-0 start-100 translate-middle badge rounded-pill bg-danger">
                        <%= alerts.length %>
                    </span>
                <% } %>
            </a>
            <ul class="dropdown-menu dropdown-menu-end shadow" style="width: 300px;">
                <li><h6 class="dropdown-header">การแจ้งเตือน</h6></li>
                
                <% if (alerts.length === 0) { %>
                    <li><a class="dropdown-item text-muted text-center" href="#">ไม่มีการแจ้งเตือน</a></li>
                <% } else { %>
                    <% alerts.forEach(feeder => { %>
                        <li>
                            <a class="dropdown-item" href="/dashboard/<%= feeder.dashboardID %>">
                                <small class="fw-bold d-block"><%= feeder.feederName %></small>
                                <% if (feeder.foodlvl < 20) { %>
                                    <span class="text-danger" style="font-size: 0.85rem;">⚠️ อาหารต่ำ (<%= feeder.foodlvl %>%)</span><br>
                                <% } %>
                                <% if (feeder.waterlvl < 20) { %>
                                    <span class="text-danger" style="font-size: 0.85rem;">💧 น้ำต่ำ (<%= feeder.waterlvl %>%)</span>
                                <% } %>
                            </a>
                        </li>
                        <li><hr class="dropdown-divider"></li>
                    <% }) %>
                <% } %>
            </ul>
        </div>
    </div>
</nav>

<div class="offcanvas offcanvas-start" tabindex="-1" id="offcanvas" aria-labelledby="offcanvasExampleLabel">
    <div class="offcanvas-header">
        <h5 class="offcanvas-title">Menu</h5>
        <button type="button" class="btn-close text-reset" data-bs-dismiss="offcanvas" aria-label="Close"></button>
    </div>
    
    <div class="offcanvas-body d-flex flex-column">
        <div class="mb-auto"> <h6 class="text-muted mb-3">All Devices</h6>
            <% if (typeof user !== 'undefined' && user) { %>
                <div id="dashboardList">
                    <% if (dashboards.length > 0) { %>
                        <% dashboards.forEach(d => { %>
                            <a href="/dashboard/<%= d.id %>" class="btn btn-outline-secondary w-100 mb-2 text-start"><%= d.name %></a>
                        <% }) %>
                    <% } else { %>
                        <p class="text-muted small">ยังไม่มี Dashboard</p>
                    <% } %>
                </div>
                <a class="btn btn-primary w-100 mt-3" data-bs-toggle="modal" data-bs-target="#addDashboard">+ เพิ่ม Dashboard</a>
            <% } else { %>
                <p class="text-muted small">กรุณาเข้าสู่ระบบเพื่อดูอุปกรณ์</p>
            <% } %>
        </div>

        <!-- responsive -->
        <div class="d-md-none mt-4 border-top pt-3">
            <% if (typeof user !== 'undefined' && user) { %>

                <div class="d-flex align-items-center mb-3">
                    <img src="https://www.svgrepo.com/show/526700/user-circle.svg" alt="profile" width="30" height="30" class="me-2">
                    <strong><%= user.username %></strong>
                </div>
                
                <a href="/profile" class="btn login-btn w-100 mb-2">Profile</a>
                
                <% if (user.urole == 'admin') { %>
                    <a href="/admindashboard" class="btn admin-btn w-100 mb-2">Admin Dashboard</a>
                <% } %>

                <form action="/logout" method="GET" class="w-100">
                    <button type="submit" class="btn register-btn w-100">Logout</button>
                </form>
            <% } else { %>
                <div class="d-grid gap-2">
                    <a href="/login" class="btn login-btn">Sign In</a>
                    <a href="/register" class="btn register-btn">Sign Up</a>
                </div>
            <% } %>
        </div>

    </div>
</div>

<%- include('namingModal') %>