<!-- views/partials/navbar.ejs -->
<nav class="navbar navbar-expand-md justify-content-center p-4 custombar mb-5">
    <div class="container-fluid position-relative">
        <button class="btn me-3" type="button" data-bs-toggle="offcanvas" data-bs-target="#offcanvas">
            ☰
        </button>

        <a class="navbar-brand position-absolute start-50 translate-middle-x brand-txt" href="/index">ECP SMART PET FEEDER</a>

        <div class="d-flex">
            <% if (typeof user !== 'undefined' && user) { %>
                <a class="mx-3 login-btn" href="/profile">
                    <img src="https://www.svgrepo.com/show/526700/user-circle.svg" alt="profile" width="16" height="16">
                    <span class="ms-1"><%= user.username %></span>
                </a>
                <form action="/logout" method="GET">
                    <button type="submit" class="logout-btn">
                        <img src="https://www.svgrepo.com/show/521174/logout.svg" alt="logout" width="16" height="16">
                    </button>
                </form>
            <% } else { %>
                <a href="/login" class="login-btn mx-3">Sign In</a>
                <a href="/register" class="register-btn">Sign Up</a>
            <% } %>
        </div>
    </div>
</nav>

<!--offcanvas-->
    <div class="offcanvas offcanvas-start" tabindex="-1" id="offcanvas" aria-labelledby="offcanvasExampleLabel">
        <div class="offcanvas-header">
            <h5 class="offcanvas-title">All Devices</h5>
            <button type="button" class="btn-close text-reset" data-bs-dismiss="offcanvas" aria-label="Close"></button>
        </div>
        <div class="offcanvas-body">
            <div class="dropdown mt-3 d-flex flex-column">
                <a class="btn btn-secondary mb-3" type="button" href="../dashboardcam">
                    Dashboard test
                </a>
                <a class="btn btn-secondary mb-3" type="button" href="../testboard">
                    Dashboard 2
                </a>
                <% if (dashboards && dashboards.length > 0) { %>
                    <% dashboard.forEach(d => { %>
                    <a class="btn btn-secondary mb-3" href="/dashboard/<%= d.id %>"><%= d.name %></a>
                    <% }) %>
                <% } else { %>
                    <p>ยังไม่มี dashboard</p>
                <% } %>
                <button id="addDashboardBtn" class="btn btn-success">+ Add Dashboard</button>
                <script>
                    document.getElementById('addDashboardBtn').addEventListener('click', async () => {
                    const name = prompt("ตั้งชื่อ Dashboard ใหม่:");
                    if (!name) return;

                    const res = await fetch('/add-dashboard', {
                        method: 'POST',
                        headers: { 'Content-Type': 'application/json' },
                        body: JSON.stringify({ name })
                    });

                    const result = await res.json();
                    if (result.success) {
                        alert("เพิ่ม Dashboard สำเร็จ!");
                        window.location.reload();
                    } else {
                        alert("เกิดข้อผิดพลาด: " + result.message);
                    }
                    });
                </script>
            </div>
        </div>
    </div>
